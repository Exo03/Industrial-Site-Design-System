  <property name="styleSheet">
   <string notr="true">QDialog {
        background-color: #1E1E1E;
        color: #FFFFFF;
        border: 1px solid #333333;
        border-radius: 8px;
        padding: 16px;
    }

    QLabel {
        font-weight: bold;
        color: #FFFFFF;
        margin-bottom: 4px;
    }

    QLineEdit {
        background-color: #2A2A2A;
        color: #FFFFFF;
        border: 1px solid #333333;
        border-radius: 4px;
        padding: 6px 8px;
    }

    QLineEdit:focus {
        border: 1px solid #BB86FC;
        outline: none;
    }

    /* Поле для отображения цвета — с заливкой */
    QLineEdit#colorDisplay {
        background-color: #121212;  /* фон — как у главного окна */
        border: 1px solid #333333;
        border-radius: 4px;
        padding: 6px 8px;
    }

    QPushButton {
        background-color: #2A2A2A;
        color: #FFFFFF;
        border: 1px solid #333333;
        border-radius: 4px;
        padding: 6px 16px;
        font-weight: 500;
    }

    QPushButton:hover {
        background-color: #333333;
    }

    QPushButton:pressed {
        background-color: #BB86FC;
        color: black;
    }

    QPushButton#okButton {
        background-color: #BB86FC;
        color: black;
        border: 1px solid #BB86FC;
    }

    QPushButton#okButton:hover {
        background-color: #CC99FF;
    }

    QPushButton#okButton:pressed {
        background-color: #AA77DD;
    }

    QPushButton#colorButton {
        background-color: #2A2A2A;
        border: 1px solid #333333;
        border-radius: 4px;
        padding: 0;
    }

    QPushButton#colorButton:hover {
        background-color: #333333;
    }</string>
