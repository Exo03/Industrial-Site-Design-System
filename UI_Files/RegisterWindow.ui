    color: #FFFFFF;
    border: 1px solid #333333;
    padding: 8px 20px;
    border-radius: 4px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #333333;
}

QPushButton:pressed {
    background-color: #BB86FC;
    color: black;
}
QLabel#ifExist {
    color: #BB86FC;
    text-decoration: underline;
    cursor: pointer;
    padding: 4px 0px;
    qproperty-alignment: AlignRight;
}</string>
