  <property name="styleSheet">
   <string notr="true">/* Общий фон окна авторизации */
QWidget {
    background-color: #121212;
    color: #FFFFFF;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

/* Заголовок &quot;Авторизация&quot; */
QLabel#titleLabel {
    font-size: 20pt;
    font-weight: bold;
    color: #FFFFFF;
    qproperty-alignment: AlignCenter;
    margin-bottom: 20px;
}

/* Метки &quot;Логин&quot;, &quot;Пароль&quot; */
QLabel {
    color: #FFFFFF;
    font-size: 11pt;
    padding: 4px 0px;
}

/* Поля ввода */
QLineEdit {
    background-color: #1E1E1E;
    color: #FFFFFF;
    border: 1px solid #333333;
    padding: 6px 10px;
    border-radius: 4px;
    selection-background-color: #BB86FC;
    selection-color: black;
}

/* Кнопка &quot;Войти&quot; */
QPushButton {
    background-color: #1E1E1E;
    color: #FFFFFF;
    border: 1px solid #333333;
    padding: 8px 20px;
    border-radius: 4px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #333333;
}

QPushButton:pressed {
    background-color: #BB86FC;
    color: black;
}

/* Гиперссылки: &quot;Забыли пароль?&quot;, &quot;Регистрация&quot; */
QLabel#forgotPasswordLink,
QLabel#registerLink {
    color: #BB86FC;
    text-decoration: underline;
    cursor: pointer;
    padding: 4px 0px;
    qproperty-alignment: AlignRight;
}

QLabel#registerLink {
    qproperty-alignment: AlignCenter;
    margin-top: 10px;
}

QLabel#forgotPasswordLink:hover,
QLabel#registerLink:hover {
    color: #FFFFFF;
}</string>
