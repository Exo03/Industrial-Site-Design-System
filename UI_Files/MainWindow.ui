                border: 1px solid #333333;
                padding: 6px 12px;
                border-radius: 4px;
                font-weight: 500;
            }
            QToolButton:hover {
                background: #333333;
            }
            QToolButton:pressed {
                background: #BB86FC;
                color: black;
            }

            QComboBox {
                background-color: #1E1E1E;
                color: #FFFFFF;
                border: 1px solid #333333;
                padding: 3px 6px;
                min-width: 120px;
            }
            QComboBox::drop-down {
                border-left: 1px solid #333333;
            }
